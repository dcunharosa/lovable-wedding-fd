# RSVP Form — Google Sheets backend
#
# Setup:
# 1. Create a new Google Sheet
# 2. Go to Extensions → Apps Script
# 3. Paste the contents of google-apps-script.js (in this repo)
# 4. Set ADMIN_SECRET in the script to a random string
# 5. Run the "setupHeaders" function once (adds column headers)
# 6. Click Deploy → New deployment → Web app
# 7. Set "Execute as" = Me, "Who has access" = Anyone
# 8. Copy the deployment URL below

# Public: used by the RSVP form (exposed to browser via VITE_ prefix)
VITE_RSVP_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Admin: used by Vercel serverless functions (server-side only, NOT exposed to browser)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
APPS_SCRIPT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
ADMIN_PASSWORD=CHANGE_ME_TO_YOUR_PASSWORD
